# Until Then environment. Copy to .env.local and fill in. NEVER commit .env.local.
# NEXT_PUBLIC_* are exposed to the browser; everything else is server-only and must never be
# prefixed NEXT_PUBLIC_ or imported into a "use client" file.

# --- network / chain ---
# The app FOLLOWS the connected wallet's network (no in-app selector). Set Petra to Shelbynet or
# Testnet and the app runs there. APTOS_NETWORK / SHELBY_NETWORK below are now only a default hint for
# the wallet adapter and a fallback for code paths that run without a wallet.
NEXT_PUBLIC_APTOS_NETWORK=shelbynet
NEXT_PUBLIC_SHELBY_NETWORK=shelbynet
# Per-network deployed `until_then` module address — the app picks the one matching the wallet's net.
# Shelby storage exists only on shelbynet + testnet, so mainnet/devnet are recognized but show "coming
# soon" (no contract address needed there yet).
NEXT_PUBLIC_DEADDROP_CONTRACT_ADDRESS=           # Shelbynet module address (legacy name; still the Shelbynet fallback)
NEXT_PUBLIC_CONTRACT_ADDRESS_SHELBYNET=          # optional explicit Shelbynet address (overrides the legacy var above)
NEXT_PUBLIC_CONTRACT_ADDRESS_TESTNET=            # set after deploying until_then to Aptos Testnet
# Only needed if Petra surfaces Shelbynet as a "custom" network (name != "shelbynet"): set its chain id
# so the app can map it. Find it by logging useWallet().network while connected to Shelbynet.
NEXT_PUBLIC_SHELBYNET_CHAIN_ID=
NEXT_PUBLIC_APP_URL=http://localhost:3000        # used to build email retrieval links

# --- Shelby blob storage ---
# Mock (default): blobs in IndexedDB/in-memory, no tokens needed. Set "false" for the real network.
# In real mode the OWNER WALLET signs + pays the upload and the blob is stored under its address;
# download is signer-less. No server account, no subsidy — there are no uploader-key env vars.
NEXT_PUBLIC_USE_SHELBY_MOCK=true
# Per-blob lifetime cap (hours). Shelbynet enforces 48h; longer locks need owner renewal (or testnet).
NEXT_PUBLIC_SHELBY_MAX_BLOB_HOURS=48
# Shelby API key (from the Shelby portal: docs.shelby.xyz/sdks/typescript/acquire-api-keys). Raises the
# RPC rate limit. NOT a secret on Shelbynet — the browser uses it too. Optional; unset = more 429s.
NEXT_PUBLIC_SHELBY_API_KEY=

# --- Supabase ---
# When BOTH the URL and the service-role key are set, the app uses real Supabase; otherwise the
# in-memory mock. Apply supabase/migrations/0001_initial.sql then 0002_atomic_functions.sql first.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=                   # public anon key (RLS-protected)
SUPABASE_SERVICE_ROLE_KEY=                       # SERVER-ONLY admin key (bypasses RLS)

# --- Resend (email) ---
RESEND_API_KEY=                                  # SERVER-ONLY. Email only sends when this is set.
EMAIL_FROM=notifications@yourdomain.com          # must be on a Resend-verified domain
EMAIL_REPLY_TO=support@yourdomain.com

# --- server secrets ---
CRON_SECRET=                                     # protects GET /api/cron/release (Bearer token)
QSTASH_TOKEN=                                     # Upstash QStash — schedules one-shot release at the safe's time (optional; daily cron is the backstop)
QSTASH_URL=                                       # QStash base URL — only needed if your QStash region isn't the EU default (https://qstash.upstash.io)
EMAIL_ENC_KEY=                                   # 32 bytes as hex(64 chars) or base64 — email-at-rest
AUTH_SESSION_SECRET=                             # signs SIWA session cookies — `node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"`
